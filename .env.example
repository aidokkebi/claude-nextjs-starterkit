# ========== 데이터베이스 ==========
# Supabase 프로젝트 설정에서 Connection String을 복사하세요
# Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ========== Auth.js ==========
# 아래 명령어로 자동 생성: npx auth secret
AUTH_SECRET="your-secret-key-here"

# ========== 카카오 로그인 ==========
# https://developers.kakao.com 에서 앱 생성 후 발급
# My Application > App Settings > Summary > App Keys > REST API key
AUTH_KAKAO_ID="your-kakao-client-id"
AUTH_KAKAO_SECRET="your-kakao-client-secret"

# ========== 네이버 로그인 ==========
# https://developers.naver.com 에서 앱 등록 후 발급
AUTH_NAVER_ID="your-naver-client-id"
AUTH_NAVER_SECRET="your-naver-client-secret"

# ========== 구글 로그인 ==========
# https://console.cloud.google.com 에서 OAuth 클라이언트 생성
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ========== 토스페이먼츠 ==========
# https://developers.tosspayments.com 에서 발급
# 테스트 키: test_ck_... / 실제 키: live_ck_...
TOSS_CLIENT_KEY="test_ck_your-toss-client-key"
TOSS_SECRET_KEY="test_sk_your-toss-secret-key"

# ========== 앱 URL ==========
NEXTAUTH_URL="http://localhost:3000"
